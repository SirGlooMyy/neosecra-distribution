# NeoSecra Security Health (V1) — environment template.
#
# HOW TO USE:
#   cp .env.v1.example .env.v1
#   # then fill every CHANGE_ME value with real production secrets
#   # .env.v1 is gitignored and is NEVER shipped with the release package
#
# This file contains PLACEHOLDERS ONLY. Real secret generation (random DB
# password, SECRET_KEY, OTP/SMTP creds) is left to runtime/operator. Never
# commit a filled .env.v1. Full field list: backend/app/config.py (Settings).

# --- Compose interpolation (read by docker-compose.v1.yml) ---
NEOSECRA_VERSION=1.0.8
POSTGRES_IMAGE=postgres:15.18-alpine3.24
REDIS_IMAGE=redis:7.4.9-alpine3.21
BACKEND_IMAGE=ghcr.io/sirgloomyy/neosecra-assessment/security-health-backend:1.0.8
WORKER_IMAGE=ghcr.io/sirgloomyy/neosecra-assessment/security-health-backend:1.0.8
FRONTEND_IMAGE=ghcr.io/sirgloomyy/neosecra-assessment/security-health-frontend:1.0.8
OPENVAS_IMAGE=immauss/openvas:26.07.12.01

# PostgreSQL (host port -> container 5432)
POSTGRES_USER=neosecra
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=neosecra_assessment
POSTGRES_PORT=25433

# Host port mapping overrides (defaults shown; offset these if V2 runs side-by-side)
REDIS_PORT=23639
BACKEND_PORT=23800
FRONTEND_PORT=23300

# --- Backend Settings (pydantic BaseSettings, snake_case -> UPPER) ---
# Application
NEOSECRA_EDITION=security_health
VITE_NEOSECRA_EDITION=security-health
ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://neosecra:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/neosecra_assessment
REDIS_URL=redis://redis:6379/0
# JWT/session signing key — generate with: openssl rand -hex 48
SECRET_KEY=CHANGE_ME_SECRET_KEY_AT_LEAST_32_CHARS_NO_COMMON_WORDS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=http://localhost:23300,http://127.0.0.1:23300

# First admin bootstrap (used only on initial migration/seed)
FIRST_ADMIN_EMAIL=admin@neosecra.io
FIRST_ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
ADMIN_RECOVERY_KEY=CHANGE_ME_EMERGENCY_RECOVERY_KEY

# Storage (container paths backed by named volumes)
UPLOAD_DIR=/app/uploads
REPORT_DIR=/app/reports

# Data retention (days)
DATA_RETENTION_ENABLED=true
DATA_RETENTION_DAYS=365
DATA_RETENTION_FAILED_DAYS=90

# Notifications (email) — optional, leave blank to disable
NOTIFICATION_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@neosecra.local
SMTP_FROM_NAME=NeoSecra Security Platform
NOTIFICATION_EMAIL_RECIPIENTS=

# Product branding (MSSP white-label) — optional
PRODUCT_NAME=NeoSecra
PRODUCT_FULL_NAME=NeoSecra Security Platform
PRODUCT_VENDOR_NAME=
PRODUCT_WEBSITE=
PRODUCT_SUPPORT_EMAIL=

# AI agent (optional, leave blank to disable)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- OpenVAS (optional, profile openvas only) ---
OV_USER=admin
OV_PASSWORD=CHANGE_ME_OPENVAS_PASSWORD
OPENVAS_SSH_PORT=23922
OPENVAS_GSAD_PORT=23992
# Backend connection to the OpenVAS scanner container (used by scans)
OPENVAS_HOST=openvas
OPENVAS_PORT=22
OPENVAS_USER=gvm
OPENVAS_PASS=CHANGE_ME_OPENVAS_GVM_PASSWORD
OPENVAS_GMP_USER=admin
OPENVAS_GMP_PASS=CHANGE_ME_OPENVAS_GMP_PASSWORD
OPENVAS_CONFIG_ID=daba56c8-73ec-11df-a475-002264764cea
OPENVAS_MOCK=false
OPENVAS_KNOWN_HOSTS=
